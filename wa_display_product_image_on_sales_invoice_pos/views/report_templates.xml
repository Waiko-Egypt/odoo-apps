<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Sale Order / Quotation Report: Add Image column              -->
    <!-- Odoo 19 — same QWeb xpath names; image_data_uri() available  -->
    <!-- ============================================================ -->
    <template id="report_saleorder_document_image"
              inherit_id="sale.report_saleorder_document">

        <xpath expr="//th[@name='th_description']" position="after">
            <th name="th_image" t-if="doc.company_id.show_product_image_in_reports"
                class="text-center" style="width: 80px;">
                <span>Image</span>
            </th>
        </xpath>

        <xpath expr="//td[@name='td_name']" position="after">
            <td name="td_image" t-if="doc.company_id.show_product_image_in_reports"
                class="text-center" style="vertical-align: middle; padding: 2px;">
                <t t-if="line.product_id.image_128">
                    <img t-att-src="image_data_uri(line.product_id.image_128)"
                         t-attf-width="#{doc.company_id.product_image_width}"
                         t-attf-height="#{doc.company_id.product_image_height}"
                         style="object-fit: contain;"
                         alt="Product Image"/>
                </t>
            </td>
        </xpath>

    </template>

    <!-- ============================================================ -->
    <!-- Invoice Report: Add Image column                             -->
    <!-- Odoo 19 — account.report_invoice_document template           -->
    <!-- ============================================================ -->
    <template id="report_invoice_document_image"
              inherit_id="account.report_invoice_document">

        <xpath expr="//th[@name='th_description']" position="after">
            <th name="th_image" t-if="o.company_id.show_product_image_in_reports"
                class="text-center" style="width: 80px;">
                <span>Image</span>
            </th>
        </xpath>

        <xpath expr="//td[@name='account_invoice_line_name']" position="after">
            <td name="td_image" t-if="o.company_id.show_product_image_in_reports"
                class="text-center" style="vertical-align: middle; padding: 2px;">
                <t t-if="line.product_id.image_128">
                    <img t-att-src="image_data_uri(line.product_id.image_128)"
                         t-attf-width="#{o.company_id.product_image_width}"
                         t-attf-height="#{o.company_id.product_image_height}"
                         style="object-fit: contain;"
                         alt="Product Image"/>
                </t>
            </td>
        </xpath>

    </template>

</odoo>
