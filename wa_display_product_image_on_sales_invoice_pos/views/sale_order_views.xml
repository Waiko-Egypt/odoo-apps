<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Odoo 14: tree view still uses <tree>.
        optional="show" added (introduced in v14) so the column is
        hidden by default but the user can toggle it from the column menu.
    -->
    <record id="view_order_form_inherit_product_image" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.product.image</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/tree//field[@name='product_id']" position="after">
                <field name="product_image" widget="image"
                       options="{'size': [40, 40]}"
                       string="Image"
                       readonly="1"
                       nolabel="1"
                       optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
