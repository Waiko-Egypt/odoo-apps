<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Odoo 16: tree view tag is deprecated in favour of list, but the
        xpath still resolves correctly because Odoo 16 renders both.
        We keep <tree> in the xpath for safety; switch to <list> in v17+.
        optional="show" makes the image column toggleable per user.
    -->
    <record id="view_order_form_inherit_product_image" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.product.image</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/tree//field[@name='product_id']" position="after">
                <field name="product_image" widget="image"
                       options="{'size': [40, 40]}"
                       string="Image"
                       readonly="1"
                       nolabel="1"
                       optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
