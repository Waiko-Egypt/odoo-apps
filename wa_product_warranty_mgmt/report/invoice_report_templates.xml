<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend Invoice Report to add Warranty Column and Dates -->
    <template id="report_invoice_document_warranty"
              inherit_id="account.report_invoice_document">

        <!-- Add Warranty column header before Quantity -->
        <xpath expr="//th[@name='th_quantity']" position="before">
            <th name="th_warranty" class="text-left"><span>Warranty</span></th>
        </xpath>

        <!-- Add Warranty value cell before Quantity in each line -->
        <xpath expr="//td[@name='td_quantity']" position="before">
            <td name="td_warranty" style="font-size: 0.9em; vertical-align: middle;">
                <t t-if="line.product_id and line.warranty_description">
                    <span t-field="line.warranty_description"/>
                    <t t-if="line.warranty_start_date">
                        <br/>
                        <small style="color:#666;">
                            From: <span t-field="line.warranty_start_date"/><br/>
                            To: <span t-field="line.warranty_end_date"/>
                        </small>
                    </t>
                </t>
            </td>
        </xpath>

    </template>

</odoo>
