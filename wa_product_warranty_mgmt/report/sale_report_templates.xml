<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend Sale Order Report to add Warranty Column -->
    <template id="report_saleorder_document_warranty"
              inherit_id="sale.report_saleorder_document">

        <!-- Add Warranty column header before Quantity -->
        <xpath expr="//th[@name='th_quantity']" position="before">
            <th name="th_warranty" class="text-start text-nowrap">Warranty</th>
        </xpath>

        <!-- Add Warranty value cell before Quantity in each line -->
        <xpath expr="//td[@name='td_quantity']" position="before">
            <td name="td_warranty">
                <span t-if="line.warranty_description" t-field="line.warranty_description"/>
            </td>
        </xpath>

    </template>

</odoo>
